{
  "info": {
    "name": "Ecommerce Store API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081"
    },
    {
      "key": "geo_id",
      "value": "US"
    },
    {
      "key": "discount_code",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Configure Geo",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/config",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"geoId\": \"{{geo_id}}\",\n  \"nthOrder\": 3,\n  \"discountPercentage\": 10\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has geoId', () => pm.expect(pm.response.json().geoId).to.eql(pm.collectionVariables.get('geo_id')));"
                ]
              }
            }
          ]
        },
        {
          "name": "Generate Discount Code",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/generate-discount",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"geoId\": \"{{geo_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.code) {",
                  "  pm.collectionVariables.set('discount_code', json.code);",
                  "  console.log('Captured discount code:', json.code);",
                  "}",
                  "pm.test('Code is unused', () => pm.expect(json.used).to.be.false);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Analytics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/analytics?geoId={{geo_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "analytics"],
              "query": [{ "key": "geoId", "value": "{{geo_id}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has totalOrders', () => pm.expect(json).to.have.property('totalOrders'));",
                  "pm.test('Has totalRevenue', () => pm.expect(json).to.have.property('totalRevenue'));",
                  "pm.test('Has discountCodes', () => pm.expect(json.discountCodes).to.be.an('array'));",
                  "console.log('Total orders:', json.totalOrders, '| Revenue:', json.totalRevenue, '| Discounts given:', json.totalDiscountAmount);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Customer",
      "item": [
        {
          "name": "Add to Cart - user1",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/cart/add",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user1\",\n  \"geoId\": \"{{geo_id}}\",\n  \"productId\": \"p1\",\n  \"name\": \"Headphones\",\n  \"price\": 100.0,\n  \"quantity\": 1\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Item in cart', () => pm.expect(pm.response.json().items.length).to.be.above(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "Add to Cart - user2",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/cart/add",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user2\",\n  \"geoId\": \"{{geo_id}}\",\n  \"productId\": \"p2\",\n  \"name\": \"Keyboard\",\n  \"price\": 80.0,\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "name": "Add to Cart - user3 (nth order user)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/cart/add",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user3\",\n  \"geoId\": \"{{geo_id}}\",\n  \"productId\": \"p3\",\n  \"name\": \"Monitor\",\n  \"price\": 200.0,\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "name": "Checkout - user1 (order 1)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user1\",\n  \"geoId\": \"{{geo_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('No discount applied', () => pm.expect(pm.response.json().discountAmount).to.eql(0));",
                  "pm.test('nth order NOT reached', () => pm.expect(pm.response.json().nthOrderReached).to.be.false);"
                ]
              }
            }
          ]
        },
        {
          "name": "Checkout - user2 (order 2)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user2\",\n  \"geoId\": \"{{geo_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('nth order NOT reached', () => pm.expect(pm.response.json().nthOrderReached).to.be.false);"
                ]
              }
            }
          ]
        },
        {
          "name": "Checkout - user3 (order 3, nth!)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user3\",\n  \"geoId\": \"{{geo_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('nth order reached', () => pm.expect(pm.response.json().nthOrderReached).to.be.true);",
                  "console.log('nth order reached! Admin should now call Generate Discount Code.');"
                ]
              }
            }
          ]
        },
        {
          "name": "Checkout - user3 WITH discount",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user3\",\n  \"geoId\": \"{{geo_id}}\",\n  \"discountCode\": \"{{discount_code}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Discount was applied', () => pm.expect(json.discountAmount).to.be.above(0));",
                  "pm.test('Total is subtotal minus discount', () => pm.expect(json.total).to.eql(json.subtotal - json.discountAmount));",
                  "console.log('Discount applied:', json.discountAmount, '| Final total:', json.total);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Checkout - empty cart",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"ghost_user\",\n  \"geoId\": \"{{geo_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has error message', () => pm.expect(pm.response.json()).to.have.property('error'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Checkout - invalid discount code",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user1\",\n  \"geoId\": \"{{geo_id}}\",\n  \"discountCode\": \"INVALIDCODE\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has error message', () => pm.expect(pm.response.json()).to.have.property('error'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Generate discount - conditions not met",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/generate-discount",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"geoId\": \"{{geo_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('Has error message', () => pm.expect(pm.response.json()).to.have.property('error'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Configure geo - unconfigured geo checkout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user1\",\n  \"geoId\": \"IN\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has error message', () => pm.expect(pm.response.json()).to.have.property('error'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
